# Hasura GraphQL Engine environment configuration
# Copy to app.env and customize before starting

# Timezone
TZ=America/New_York

# Hostname
BASE_HOST_NAME=hasura.example.com

# Admin secret (protects the console and API)
APP_ADMIN_PASS=changeme_admin_password

# JWT secret key (min 32 chars, HS256)
APP_SECRET_KEY=changeme_secret_key_min_32_chars

# Database (PostgreSQL)
DB_CREATE_DATABASE_NAME=hasura
DB_USER_NAME=hasura
DB_USER_PASS=changeme_db_password
